{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "brainX",
  "version": "0.1.0",
  "identifier": "com.brainx.desktop",
  "bundle": {
    "externalBin": ["binaries/brainx-backend"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://example.com/brainx/latest.json"],
      "pubkey": ""
    }
  },
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "brainX",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8420 http://127.0.0.1:8420 http://localhost:8000 http://127.0.0.1:8000; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:;"
    }
  }
}
